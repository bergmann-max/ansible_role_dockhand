{# Managed by Ansible – role: dockhand #}
{# Manual changes will be overwritten on the next Ansible run! #}
PUID={{ dockhand_puid }}
PGID={{ dockhand_pgid }}
DATA_DIR=/app/data
{% if dockhand_secret_key %}
SECRET_KEY={{ dockhand_secret_key }}
{% endif %}
{% if dockhand_database_url %}
DATABASE_URL={{ dockhand_database_url }}
{% endif %}
DISABLE_LOCAL_LOGIN={{ dockhand_disable_local_login | lower }}
{% if dockhand_skip_df_collection %}
SKIP_DF_COLLECTION=1
{% endif %}
